[Unit]
Description=NETRUN Orchestrator Worker
After=network-online.target postgresql.service netrun-orchestrator.service
Wants=network-online.target

[Service]
Type=simple
WorkingDirectory=/opt/netrun-orchestrator
EnvironmentFile=/opt/netrun-orchestrator/.env
ExecStart=/opt/netrun-orchestrator/.venv/bin/python -m orchestrator.worker
Restart=always
RestartSec=3
LimitNOFILE=65536

[Install]
WantedBy=multi-user.target
