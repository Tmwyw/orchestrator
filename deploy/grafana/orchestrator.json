{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": "-- Grafana --",
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "NETRUN Orchestrator — HTTP, schedulers, allocator, traffic-poll (Wave D).",
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "tags": ["netrun", "orchestrator"],
  "timezone": "browser",
  "title": "NETRUN Orchestrator",
  "uid": "netrun-orchestrator",
  "version": 1,
  "time": {"from": "now-6h", "to": "now"},
  "refresh": "30s",
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": {"text": "Prometheus", "value": "Prometheus"},
        "label": "Prometheus"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "timeseries",
      "title": "HTTP request rate (req/s)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 0},
      "targets": [
        {
          "expr": "sum by (path) (rate(netrun_http_requests_total[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "HTTP 5xx error rate (req/s)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 0},
      "targets": [
        {
          "expr": "sum by (path) (rate(netrun_http_requests_total{status=~\"5..\"}[5m]))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"color": {"mode": "palette-classic"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 0.01}]}}
      }
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "HTTP p95 latency (s)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 8},
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, path) (rate(netrun_http_duration_sec_bucket[5m])))",
          "legendFormat": "{{path}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Reserve / commit / release rate",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 8},
      "targets": [
        {
          "expr": "sum by (status) (rate(netrun_reserve_total[5m]))",
          "legendFormat": "reserve {{status}}",
          "refId": "A"
        },
        {
          "expr": "sum by (status) (rate(netrun_commit_total[5m]))",
          "legendFormat": "commit {{status}}",
          "refId": "B"
        },
        {
          "expr": "sum by (status) (rate(netrun_release_total[5m]))",
          "legendFormat": "release {{status}}",
          "refId": "C"
        }
      ]
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Scheduler runs (per-scheduler success/failed)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 16},
      "targets": [
        {
          "expr": "sum by (scheduler, status) (rate(netrun_scheduler_run_total[5m]))",
          "legendFormat": "{{scheduler}} {{status}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Watchdog actions (per action)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 16},
      "targets": [
        {
          "expr": "sum by (action) (rate(netrun_watchdog_actions_total[15m]))",
          "legendFormat": "{{action}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Inventory available (per SKU)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 24},
      "targets": [
        {
          "expr": "sum by (sku_code) (netrun_inventory_available)",
          "legendFormat": "{{sku_code}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 8,
      "type": "stat",
      "title": "Pergb accounts (active / depleted)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 24},
      "targets": [
        {
          "expr": "netrun_traffic_accounts_active",
          "legendFormat": "active",
          "refId": "A"
        },
        {
          "expr": "netrun_traffic_accounts_depleted",
          "legendFormat": "depleted",
          "refId": "B"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Traffic poll lag (s)",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 32},
      "targets": [
        {
          "expr": "netrun_traffic_poll_lag_sec",
          "legendFormat": "lag",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {"unit": "s", "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "yellow", "value": 60}, {"color": "red", "value": 180}]}}
      }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Billed bytes/s by SKU + direction",
      "datasource": {"type": "prometheus", "uid": "${datasource}"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 32},
      "targets": [
        {
          "expr": "sum by (sku_code, direction) (rate(netrun_traffic_bytes_total[5m]))",
          "legendFormat": "{{sku_code}} {{direction}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    }
  ]
}
